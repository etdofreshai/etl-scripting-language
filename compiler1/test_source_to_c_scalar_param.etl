extern fn etl_write_file1024(path i8[64], buf i8[262144], len i32) i32

fn emit_case(source i8[131072], source_len i32, path i8[64]) i32
  let tokens Token[32768]
  let ast AstNode[32768]
  let out i8[262144]
  let n i32 = lex(source, source_len, tokens, 32768)
  if n < 0
    ret 1
  end
  let an i32 = parse(tokens, n, ast, 32768)
  if an < 0
    ret 2
  end
  if sema(source, tokens, ast, an) < 0
    ret 3
  end
  let emitted i32 = emit_c(source, tokens, ast, an, out, 262144)
  if emitted < 0
    ret 4
  end
  if etl_write_file1024(path, out, emitted) < 0
    ret 5
  end
  ret 0
end

fn main() i32
  let bool_source i8[131072] = "fn choose(flag bool) i32 if flag ret 42 end ret 7 end fn main() i32 ret choose(true) end"
  let bool_path i8[64] = "/tmp/etl_c1_source_to_c_bool_param.c"
  if emit_case(bool_source, 88, bool_path) != 0
    ret 1
  end

  let i8_source i8[131072] = "fn plus_one(ch i8) i32 ret ch + 1 end fn main() i32 ret plus_one(41) end"
  let i8_path i8[64] = "/tmp/etl_c1_source_to_c_i8_param.c"
  if emit_case(i8_source, 72, i8_path) != 0
    ret 2
  end

  let byte_source i8[131072] = "fn plus_one(ch byte) i32 ret ch + 1 end fn main() i32 ret plus_one(41) end"
  let byte_path i8[64] = "/tmp/etl_c1_source_to_c_byte_param.c"
  if emit_case(byte_source, 74, byte_path) != 0
    ret 3
  end

  ret 0
end
