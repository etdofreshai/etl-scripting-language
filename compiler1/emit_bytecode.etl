// ETLB1 bytecode subset emitted here:
//   ETLB1;                 module magic/version
//   T<count>;              function table count
//   D<name>,<argc>;        function table entry; VM resolves @<name>; to byte offset
//   C<name>;               call function; arguments are already on stack
//   @<name>;               function body marker
//   I<n>; L<n>; L<n>=;     literals and local load/store
//   +; -; *; /; %; q; n; <; l; >; g; !;
//   :<n>; F<n>; J<n>;      labels and branches local to the bytecode stream
//   R;                     return from function, or final program return at frame depth 0

fn emit_bytecode_append_byte(out i8[1024], pos i32, out_cap i32, value i8) i32
  if pos < 0
    ret EMIT_ERR_CAPACITY()
  end
  if pos >= out_cap
    ret EMIT_ERR_CAPACITY()
  end
  out[pos] = value
  ret pos + 1
end

fn emit_bytecode_return_i32_imm() i32 ret 16 end
fn EMIT_BC_OP_EQ() i32 ret 113 end
fn EMIT_BC_OP_NE() i32 ret 110 end
fn EMIT_BC_OP_LT() i32 ret 60 end
fn EMIT_BC_OP_LE() i32 ret 108 end
fn EMIT_BC_OP_GT() i32 ret 62 end
fn EMIT_BC_OP_GE() i32 ret 103 end
fn EMIT_BC_OP_NOT() i32 ret 33 end
fn EMIT_BC_OP_LABEL() i32 ret 58 end
fn EMIT_BC_OP_JUMP_FALSE() i32 ret 70 end
fn EMIT_BC_OP_JUMP() i32 ret 74 end

fn emit_bytecode_append_text(out i8[1024], pos i32, out_cap i32, text i8[64], len i32) i32
  let i i32 = 0
  let p i32 = pos
  while i < len
    p = emit_bytecode_append_byte(out, p, out_cap, text[i])
    if p < 0
      ret p
    end
    i = i + 1
  end
  ret p
end

fn emit_bytecode_append_i32(out i8[1024], pos i32, out_cap i32, value i32) i32
  let p i32 = pos
  let zero i8[64] = "0"
  let digits_text i8[64] = "0123456789"
  if value < 0
    ret EMIT_ERR_UNSUPPORTED()
  end
  if value == 0
    ret emit_bytecode_append_text(out, p, out_cap, zero, 1)
  end
  let digits i32[16]
  let n i32 = 0
  while value > 0
    if n >= 16
      ret EMIT_ERR_UNSUPPORTED()
    end
    digits[n] = value % 10
    value = value / 10
    n = n + 1
  end
  while n > 0
    n = n - 1
    p = emit_bytecode_append_byte(out, p, out_cap, digits_text[digits[n]])
    if p < 0
      ret p
    end
  end
  ret p
end

fn emit_bytecode_append_token_text(source i8[131072], tokens Token[32768], tok i32, out i8[1024], pos i32, out_cap i32) i32
  let p i32 = pos
  let i i32 = 0
  while i < tokens[tok].len
    p = emit_bytecode_append_byte(out, p, out_cap, source[tokens[tok].start + i])
    if p < 0
      ret p
    end
    i = i + 1
  end
  ret p
end

fn emit_bytecode_names_match(source i8[131072], tokens Token[32768], left i32, right i32) i32
  if left == right
    ret 1
  end
  if tokens[left].len != tokens[right].len
    ret 0
  end
  let i i32 = 0
  while i < tokens[left].len
    if source[tokens[left].start + i] != source[tokens[right].start + i]
      ret 0
    end
    i = i + 1
  end
  ret 1
end

fn emit_bytecode_lookup_local(source i8[131072], tokens Token[32768], scope i32[64], name i32) i32
  let count i32 = scope[0]
  let i i32 = 1
  while i <= count
    if emit_bytecode_names_match(source, tokens, scope[i], name) == 1
      ret i - 1
    end
    i = i + 1
  end
  ret -1
end

fn emit_bytecode_add_local(scope i32[64], name i32) i32
  let count i32 = scope[0]
  if count >= 32
    ret EMIT_ERR_UNSUPPORTED()
  end
  scope[0] = count + 1
  scope[count + 1] = name
  ret count
end

fn emit_bytecode_add_params(source i8[131072], tokens Token[32768], ast AstNode[32768], scope i32[64], list i32) i32
  if list < 0
    ret 0
  end
  if ast[list].kind != AN_LIST()
    ret EMIT_ERR_BAD_AST()
  end
  let prior i32 = emit_bytecode_add_params(source, tokens, ast, scope, ast[list].b)
  if prior < 0
    ret prior
  end
  let param i32 = ast[list].a
  if ast[param].kind != AN_PARAM()
    ret EMIT_ERR_BAD_AST()
  end
  ret emit_bytecode_add_local(scope, ast[param].a)
end

fn emit_bytecode_count_list(ast AstNode[32768], list i32) i32
  if list < 0
    ret 0
  end
  ret emit_bytecode_count_list(ast, ast[list].b) + 1
end

fn emit_bytecode_emit_body_marker(source i8[131072], tokens Token[32768], out i8[1024], pos i32, out_cap i32, name_tok i32) i32
  let op i8[64] = "@"
  let sep i8[64] = ";"
  let p i32 = emit_bytecode_append_text(out, pos, out_cap, op, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_token_text(source, tokens, name_tok, out, p, out_cap)
  if p < 0
    ret p
  end
  ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
end

fn emit_bytecode_emit_call_op(source i8[131072], tokens Token[32768], out i8[1024], pos i32, out_cap i32, name_tok i32) i32
  let op i8[64] = "C"
  let sep i8[64] = ";"
  let p i32 = emit_bytecode_append_text(out, pos, out_cap, op, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_token_text(source, tokens, name_tok, out, p, out_cap)
  if p < 0
    ret p
  end
  ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
end

fn emit_bytecode_emit_load_local(out i8[1024], pos i32, out_cap i32, slot i32) i32
  let load_op i8[64] = "L"
  let sep i8[64] = ";"
  let p i32 = emit_bytecode_append_text(out, pos, out_cap, load_op, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_i32(out, p, out_cap, slot)
  if p < 0
    ret p
  end
  ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
end

fn emit_bytecode_emit_store_local(out i8[1024], pos i32, out_cap i32, slot i32) i32
  let load_op i8[64] = "L"
  let store_marker i8[64] = "=;"
  let p i32 = emit_bytecode_append_text(out, pos, out_cap, load_op, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_i32(out, p, out_cap, slot)
  if p < 0
    ret p
  end
  ret emit_bytecode_append_text(out, p, out_cap, store_marker, 2)
end

fn emit_bytecode_next_label(scope i32[64]) i32
  let label i32 = scope[33]
  scope[33] = label + 1
  ret label
end

fn emit_bytecode_emit_label(out i8[1024], pos i32, out_cap i32, label i32) i32
  let op i8[64] = ":"
  let sep i8[64] = ";"
  let p i32 = emit_bytecode_append_text(out, pos, out_cap, op, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_i32(out, p, out_cap, label)
  if p < 0
    ret p
  end
  ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
end

fn emit_bytecode_emit_jump(out i8[1024], pos i32, out_cap i32, label i32) i32
  let op i8[64] = "J"
  let sep i8[64] = ";"
  let p i32 = emit_bytecode_append_text(out, pos, out_cap, op, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_i32(out, p, out_cap, label)
  if p < 0
    ret p
  end
  ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
end

fn emit_bytecode_emit_jump_false(out i8[1024], pos i32, out_cap i32, label i32) i32
  let op i8[64] = "F"
  let sep i8[64] = ";"
  let p i32 = emit_bytecode_append_text(out, pos, out_cap, op, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_i32(out, p, out_cap, label)
  if p < 0
    ret p
  end
  ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
end

fn emit_bytecode_emit_expr(source i8[131072], tokens Token[32768], ast AstNode[32768], node i32, out i8[1024], pos i32, out_cap i32, scope i32[64]) i32
  if node < 0
    ret EMIT_ERR_BAD_AST()
  end
  if ast[node].kind == AN_INT()
    let push_op i8[64] = "I"
    let sep i8[64] = ";"
    let p i32 = emit_bytecode_append_text(out, pos, out_cap, push_op, 1)
    if p < 0
      ret p
    end
    p = emit_bytecode_append_i32(out, p, out_cap, ast[node].a)
    if p < 0
      ret p
    end
    ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
  end
  if ast[node].kind == AN_NAME()
    let slot i32 = emit_bytecode_lookup_local(source, tokens, scope, ast[node].a)
    if slot < 0
      ret EMIT_ERR_UNSUPPORTED()
    end
    ret emit_bytecode_emit_load_local(out, pos, out_cap, slot)
  end
  if ast[node].kind == AN_CALL()
    let pcall i32 = emit_bytecode_emit_call_args(source, tokens, ast, ast[node].b, out, pos, out_cap, scope)
    if pcall < 0
      ret pcall
    end
    ret emit_bytecode_emit_call_op(source, tokens, out, pcall, out_cap, ast[node].a)
  end
  if ast[node].kind == AN_BINARY()
    let p i32 = emit_bytecode_emit_expr(source, tokens, ast, ast[node].b, out, pos, out_cap, scope)
    if p < 0
      ret p
    end
    p = emit_bytecode_emit_expr(source, tokens, ast, ast[node].c, out, p, out_cap, scope)
    if p < 0
      ret p
    end
    let sep i8[64] = ";"
    if ast[node].a == TK_PLUS()
      let op i8[64] = "+"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_MINUS()
      let op i8[64] = "-"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_STAR()
      let op i8[64] = "*"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_SLASH()
      let op i8[64] = "/"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_PERCENT()
      let op i8[64] = "%"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_EQEQ()
      let op i8[64] = "q"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_NEQ()
      let op i8[64] = "n"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_LT()
      let op i8[64] = "<"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_LTE()
      let op i8[64] = "l"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_GT()
      let op i8[64] = ">"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
    if ast[node].a == TK_GTE()
      let op i8[64] = "g"
      p = emit_bytecode_append_text(out, p, out_cap, op, 1)
      if p < 0
        ret p
      end
      ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
    end
  end
  if ast[node].kind == AN_UNARY()
    if ast[node].a != TK_NOT()
      ret EMIT_ERR_UNSUPPORTED()
    end
    let p4 i32 = emit_bytecode_emit_expr(source, tokens, ast, ast[node].b, out, pos, out_cap, scope)
    if p4 < 0
      ret p4
    end
    let op4 i8[64] = "!"
    let sep4 i8[64] = ";"
    p4 = emit_bytecode_append_text(out, p4, out_cap, op4, 1)
    if p4 < 0
      ret p4
    end
    ret emit_bytecode_append_text(out, p4, out_cap, sep4, 1)
  end
  ret EMIT_ERR_UNSUPPORTED()
end

fn emit_bytecode_emit_call_args(source i8[131072], tokens Token[32768], ast AstNode[32768], list i32, out i8[1024], pos i32, out_cap i32, scope i32[64]) i32
  if list < 0
    ret pos
  end
  if ast[list].kind != AN_LIST()
    ret EMIT_ERR_BAD_AST()
  end
  let p i32 = emit_bytecode_emit_call_args(source, tokens, ast, ast[list].b, out, pos, out_cap, scope)
  if p < 0
    ret p
  end
  ret emit_bytecode_emit_expr(source, tokens, ast, ast[list].a, out, p, out_cap, scope)
end

fn emit_bytecode_emit_elif_list(source i8[131072], tokens Token[32768], ast AstNode[32768], list i32, out i8[1024], pos i32, out_cap i32, scope i32[64], end_label i32) i32
  if list < 0
    ret pos
  end
  if ast[list].kind != AN_LIST()
    ret EMIT_ERR_BAD_AST()
  end
  let p i32 = emit_bytecode_emit_elif_list(source, tokens, ast, ast[list].b, out, pos, out_cap, scope, end_label)
  if p < 0
    ret p
  end
  let enode i32 = ast[list].a
  if ast[enode].kind != AN_ELIF()
    ret EMIT_ERR_BAD_AST()
  end
  let next_label i32 = emit_bytecode_next_label(scope)
  p = emit_bytecode_emit_expr(source, tokens, ast, ast[enode].a, out, p, out_cap, scope)
  if p < 0
    ret p
  end
  p = emit_bytecode_emit_jump_false(out, p, out_cap, next_label)
  if p < 0
    ret p
  end
  p = emit_bytecode_emit_stmt_list(source, tokens, ast, ast[ast[enode].b].a, out, p, out_cap, scope)
  if p < 0
    ret p
  end
  p = emit_bytecode_emit_jump(out, p, out_cap, end_label)
  if p < 0
    ret p
  end
  ret emit_bytecode_emit_label(out, p, out_cap, next_label)
end

fn emit_bytecode_emit_stmt(source i8[131072], tokens Token[32768], ast AstNode[32768], stmt i32, out i8[1024], pos i32, out_cap i32, scope i32[64]) i32
  if stmt < 0
    ret EMIT_ERR_BAD_AST()
  end
  let kind i32 = ast[stmt].kind
  if kind == AN_LET()
    if ast[stmt].c < 0
      ret EMIT_ERR_UNSUPPORTED()
    end
    let p i32 = emit_bytecode_emit_expr(source, tokens, ast, ast[stmt].c, out, pos, out_cap, scope)
    if p < 0
      ret p
    end
    let slot i32 = emit_bytecode_add_local(scope, ast[stmt].a)
    if slot < 0
      ret slot
    end
    ret emit_bytecode_emit_store_local(out, p, out_cap, slot)
  end
  if kind == AN_ASSIGN()
    let target i32 = ast[stmt].a
    if target < 0
      ret EMIT_ERR_BAD_AST()
    end
    if ast[target].kind != AN_NAME()
      ret EMIT_ERR_UNSUPPORTED()
    end
    let p2 i32 = emit_bytecode_emit_expr(source, tokens, ast, ast[stmt].b, out, pos, out_cap, scope)
    if p2 < 0
      ret p2
    end
    let slot2 i32 = emit_bytecode_lookup_local(source, tokens, scope, ast[target].a)
    if slot2 < 0
      ret EMIT_ERR_UNSUPPORTED()
    end
    ret emit_bytecode_emit_store_local(out, p2, out_cap, slot2)
  end
  if kind == AN_RET()
    let p3 i32 = emit_bytecode_emit_expr(source, tokens, ast, ast[stmt].a, out, pos, out_cap, scope)
    if p3 < 0
      ret p3
    end
    let ret_op i8[64] = "R;"
    ret emit_bytecode_append_text(out, p3, out_cap, ret_op, 2)
  end
  if kind == AN_IF()
    let next_label2 i32 = emit_bytecode_next_label(scope)
    let end_label2 i32 = emit_bytecode_next_label(scope)
    let p5 i32 = emit_bytecode_emit_expr(source, tokens, ast, ast[stmt].a, out, pos, out_cap, scope)
    if p5 < 0
      ret p5
    end
    p5 = emit_bytecode_emit_jump_false(out, p5, out_cap, next_label2)
    if p5 < 0
      ret p5
    end
    p5 = emit_bytecode_emit_stmt_list(source, tokens, ast, ast[ast[stmt].b].a, out, p5, out_cap, scope)
    if p5 < 0
      ret p5
    end
    p5 = emit_bytecode_emit_jump(out, p5, out_cap, end_label2)
    if p5 < 0
      ret p5
    end
    p5 = emit_bytecode_emit_label(out, p5, out_cap, next_label2)
    if p5 < 0
      ret p5
    end
    let elifs i32 = ast[ast[stmt].b].c
    p5 = emit_bytecode_emit_elif_list(source, tokens, ast, elifs, out, p5, out_cap, scope, end_label2)
    if p5 < 0
      ret p5
    end
    if ast[stmt].c >= 0
      p5 = emit_bytecode_emit_stmt_list(source, tokens, ast, ast[ast[stmt].c].a, out, p5, out_cap, scope)
      if p5 < 0
        ret p5
      end
    end
    ret emit_bytecode_emit_label(out, p5, out_cap, end_label2)
  end
  if kind == AN_WHILE()
    let start_label i32 = emit_bytecode_next_label(scope)
    let end_label3 i32 = emit_bytecode_next_label(scope)
    let p6 i32 = emit_bytecode_emit_label(out, pos, out_cap, start_label)
    if p6 < 0
      ret p6
    end
    p6 = emit_bytecode_emit_expr(source, tokens, ast, ast[stmt].a, out, p6, out_cap, scope)
    if p6 < 0
      ret p6
    end
    p6 = emit_bytecode_emit_jump_false(out, p6, out_cap, end_label3)
    if p6 < 0
      ret p6
    end
    p6 = emit_bytecode_emit_stmt_list(source, tokens, ast, ast[ast[stmt].b].a, out, p6, out_cap, scope)
    if p6 < 0
      ret p6
    end
    p6 = emit_bytecode_emit_jump(out, p6, out_cap, start_label)
    if p6 < 0
      ret p6
    end
    ret emit_bytecode_emit_label(out, p6, out_cap, end_label3)
  end
  ret EMIT_ERR_UNSUPPORTED()
end

fn emit_bytecode_emit_stmt_list(source i8[131072], tokens Token[32768], ast AstNode[32768], list i32, out i8[1024], pos i32, out_cap i32, scope i32[64]) i32
  if list < 0
    ret pos
  end
  if ast[list].kind != AN_LIST()
    ret EMIT_ERR_BAD_AST()
  end
  let p i32 = emit_bytecode_emit_stmt_list(source, tokens, ast, ast[list].b, out, pos, out_cap, scope)
  if p < 0
    ret p
  end
  ret emit_bytecode_emit_stmt(source, tokens, ast, ast[list].a, out, p, out_cap, scope)
end

fn emit_bytecode_find_main(ast AstNode[32768], list i32) i32
  if list < 0
    ret EMIT_ERR_UNSUPPORTED()
  end
  if ast[list].kind != AN_LIST()
    ret EMIT_ERR_BAD_AST()
  end
  let prior i32 = emit_bytecode_find_main(ast, ast[list].b)
  if prior >= 0
    ret prior
  end
  let decl i32 = ast[list].a
  if ast[decl].kind == AN_FN()
    ret decl
  end
  ret EMIT_ERR_UNSUPPORTED()
end

fn emit_bytecode_token_is_main(source i8[131072], tokens Token[32768], tok i32) i32
  let name i8[64] = "main"
  if tokens[tok].len != 4
    ret 0
  end
  if source[tokens[tok].start] != name[0]
    ret 0
  end
  if source[tokens[tok].start + 1] != name[1]
    ret 0
  end
  if source[tokens[tok].start + 2] != name[2]
    ret 0
  end
  if source[tokens[tok].start + 3] != name[3]
    ret 0
  end
  ret 1
end

fn emit_bytecode_find_named_main(source i8[131072], tokens Token[32768], ast AstNode[32768], list i32) i32
  if list < 0
    ret EMIT_ERR_UNSUPPORTED()
  end
  if ast[list].kind != AN_LIST()
    ret EMIT_ERR_BAD_AST()
  end
  let prior i32 = emit_bytecode_find_named_main(source, tokens, ast, ast[list].b)
  if prior >= 0
    ret prior
  end
  let decl i32 = ast[list].a
  if ast[decl].kind == AN_FN()
    if emit_bytecode_token_is_main(source, tokens, ast[decl].a) == 1
      ret decl
    end
  end
  ret EMIT_ERR_UNSUPPORTED()
end

fn emit_bytecode_emit_fn(source i8[131072], tokens Token[32768], ast AstNode[32768], fn_node i32, out i8[1024], pos i32, out_cap i32) i32
  if ast[fn_node].kind != AN_FN()
    ret EMIT_ERR_BAD_AST()
  end
  let body i32 = ast[fn_node].c
  if ast[body].kind != AN_BLOCK()
    ret EMIT_ERR_BAD_AST()
  end
  let stmt_list i32 = ast[body].a
  let scope i32[64]
  scope[0] = 0
  scope[33] = 0
  let params_block i32 = ast[fn_node].b
  if ast[params_block].kind != AN_BLOCK()
    ret EMIT_ERR_BAD_AST()
  end
  let pp i32 = emit_bytecode_add_params(source, tokens, ast, scope, ast[params_block].a)
  if pp < 0
    ret pp
  end
  let p i32 = emit_bytecode_emit_body_marker(source, tokens, out, pos, out_cap, ast[fn_node].a)
  if p < 0
    ret p
  end
  ret emit_bytecode_emit_stmt_list(source, tokens, ast, stmt_list, out, p, out_cap, scope)
end

fn emit_bytecode_count_fns(ast AstNode[32768], list i32) i32
  if list < 0
    ret 0
  end
  if ast[list].kind != AN_LIST()
    ret EMIT_ERR_BAD_AST()
  end
  let prior i32 = emit_bytecode_count_fns(ast, ast[list].b)
  if prior < 0
    ret prior
  end
  if ast[ast[list].a].kind == AN_FN()
    ret prior + 1
  end
  ret prior
end

fn emit_bytecode_emit_function_table(source i8[131072], tokens Token[32768], ast AstNode[32768], list i32, out i8[1024], pos i32, out_cap i32) i32
  let table_op i8[64] = "T"
  let sep i8[64] = ";"
  let count i32 = emit_bytecode_count_fns(ast, list)
  if count < 0
    ret count
  end
  let p i32 = emit_bytecode_append_text(out, pos, out_cap, table_op, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_i32(out, p, out_cap, count)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_text(out, p, out_cap, sep, 1)
  if p < 0
    ret p
  end
  ret emit_bytecode_emit_function_table_entries(source, tokens, ast, list, out, p, out_cap)
end

fn emit_bytecode_emit_function_table_entries(source i8[131072], tokens Token[32768], ast AstNode[32768], list i32, out i8[1024], pos i32, out_cap i32) i32
  if list < 0
    ret pos
  end
  if ast[list].kind != AN_LIST()
    ret EMIT_ERR_BAD_AST()
  end
  let p i32 = emit_bytecode_emit_function_table_entries(source, tokens, ast, ast[list].b, out, pos, out_cap)
  if p < 0
    ret p
  end
  let fn_node i32 = ast[list].a
  if ast[fn_node].kind != AN_FN()
    ret p
  end
  let def_op i8[64] = "D"
  let comma i8[64] = ","
  let sep i8[64] = ";"
  p = emit_bytecode_append_text(out, p, out_cap, def_op, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_token_text(source, tokens, ast[fn_node].a, out, p, out_cap)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_text(out, p, out_cap, comma, 1)
  if p < 0
    ret p
  end
  p = emit_bytecode_append_i32(out, p, out_cap, ast[ast[fn_node].b].b)
  if p < 0
    ret p
  end
  ret emit_bytecode_append_text(out, p, out_cap, sep, 1)
end

fn emit_bytecode_emit_all_fns(source i8[131072], tokens Token[32768], ast AstNode[32768], list i32, out i8[1024], pos i32, out_cap i32) i32
  if list < 0
    ret pos
  end
  if ast[list].kind != AN_LIST()
    ret EMIT_ERR_BAD_AST()
  end
  let p i32 = emit_bytecode_emit_all_fns(source, tokens, ast, ast[list].b, out, pos, out_cap)
  if p < 0
    ret p
  end
  let decl i32 = ast[list].a
  if ast[decl].kind == AN_FN()
    ret emit_bytecode_emit_fn(source, tokens, ast, decl, out, p, out_cap)
  end
  ret p
end

fn emit_bytecode(source i8[131072], tokens Token[32768], ast AstNode[32768], ast_count i32, out i8[1024], out_cap i32) i32
  if ast_count <= 0
    ret EMIT_ERR_BAD_AST()
  end
  if ast[ast_count - 1].kind != AN_PROGRAM()
    ret EMIT_ERR_BAD_AST()
  end
  let p i32 = 0
  let header i8[64] = "ETLB1;"
  p = emit_bytecode_append_text(out, p, out_cap, header, 6)
  if p < 0
    ret p
  end
  let decls i32 = ast[ast_count - 1].a
  p = emit_bytecode_emit_function_table(source, tokens, ast, decls, out, p, out_cap)
  if p < 0
    ret p
  end
  let main_fn i32 = emit_bytecode_find_named_main(source, tokens, ast, ast[ast_count - 1].a)
  if main_fn < 0
    ret main_fn
  end
  p = emit_bytecode_emit_call_op(source, tokens, out, p, out_cap, ast[main_fn].a)
  if p < 0
    ret p
  end
  let ret_op i8[64] = "R;"
  p = emit_bytecode_append_text(out, p, out_cap, ret_op, 2)
  if p < 0
    ret p
  end
  ret emit_bytecode_emit_all_fns(source, tokens, ast, decls, out, p, out_cap)
end
