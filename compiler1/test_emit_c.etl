fn check_byte(buf i8[262144], index i32, value i32) bool
  ret buf[index] == value
end

fn main() i32
  let source i8[131072] = "fn main() i32 ret 1 + 2 * (9 - 4) end"
  let tokens Token[32768]
  let ast AstNode[32768]
  let out i8[262144]
  let n i32 = lex(source, 37, tokens, 32768)
  if n != 17
    ret 1
  end
  let an i32 = parse(tokens, n, ast, 32768)
  if an < 0
    ret 2
  end
  let emitted i32 = emit_c(source, tokens, ast, an, out, 262144)
  if emitted != 86
    ret 3
  end
  if not check_byte(out, 0, 35)
    ret 4
  end
  if not check_byte(out, 1, 105)
    ret 5
  end
  if not check_byte(out, 2, 110)
    ret 6
  end
  if not check_byte(out, 20, 10)
    ret 7
  end
  if not check_byte(out, 34, 41)
    ret 8
  end
  if not check_byte(out, 35, 59)
    ret 9
  end
  if not check_byte(out, 36, 10)
    ret 10
  end
  if not check_byte(out, 37, 105)
    ret 11
  end
  if not check_byte(out, 52, 123)
    ret 12
  end
  if not check_byte(out, 63, 40)
    ret 13
  end
  if not check_byte(out, 66, 43)
    ret 14
  end
  if not check_byte(out, 68, 40)
    ret 15
  end
  if not check_byte(out, 71, 42)
    ret 16
  end
  if not check_byte(out, 73, 40)
    ret 17
  end
  if not check_byte(out, 76, 45)
    ret 18
  end
  if not check_byte(out, 82, 59)
    ret 19
  end
  if not check_byte(out, 84, 125)
    ret 20
  end
  if not check_byte(out, 85, 10)
    ret 21
  end
  ret 86
end
