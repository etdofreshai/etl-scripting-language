fn check_byte(buf i8[262144], index i32, value i32) bool
  ret buf[index] == value
end

fn main() i32
  let source i8[131072] = "fn main() i32 ret 1 + 2 * (9 - 4) end"
  let tokens Token[32768]
  let ast AstNode[32768]
  let out i8[262144]
  let n i32 = lex(source, 37, tokens, 32768)
  if n != 17
    ret 1
  end
  let an i32 = parse(tokens, n, ast, 32768)
  if an < 0
    ret 2
  end
  let emitted i32 = emit_c(source, tokens, ast, an, out, 262144)
  if emitted != 158
    ret 3
  end
  if not check_byte(out, 0, 35)
    ret 4
  end
  if not check_byte(out, 1, 105)
    ret 5
  end
  if not check_byte(out, 2, 110)
    ret 6
  end
  if not check_byte(out, 20, 10)
    ret 7
  end
  if not check_byte(out, 106, 41)
    ret 8
  end
  if not check_byte(out, 107, 59)
    ret 9
  end
  if not check_byte(out, 108, 10)
    ret 10
  end
  if not check_byte(out, 109, 105)
    ret 11
  end
  if not check_byte(out, 124, 123)
    ret 12
  end
  if not check_byte(out, 135, 40)
    ret 13
  end
  if not check_byte(out, 138, 43)
    ret 14
  end
  if not check_byte(out, 140, 40)
    ret 15
  end
  if not check_byte(out, 143, 42)
    ret 16
  end
  if not check_byte(out, 145, 40)
    ret 17
  end
  if not check_byte(out, 148, 45)
    ret 18
  end
  if not check_byte(out, 154, 59)
    ret 19
  end
  if not check_byte(out, 156, 125)
    ret 20
  end
  if not check_byte(out, 157, 10)
    ret 21
  end
  ret 158
end
