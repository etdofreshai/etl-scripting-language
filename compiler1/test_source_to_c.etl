extern fn etl_write_file1024(path i8[64], buf i8[262144], len i32) i32

fn main() i32
  let source i8[131072] = "fn main() i32 ret twice(add(20, 1)) end fn add(left i32, right i32) i32 ret left + right end fn twice(value i32) i32 ret value * 2 end"
  let tokens Token[32768]
  let ast AstNode[32768]
  let out i8[262144]
  let n i32 = lex(source, 134, tokens, 32768)
  if n < 0
    ret 1
  end
  let an i32 = parse(tokens, n, ast, 32768)
  if an < 0
    ret 2
  end
  if sema(source, tokens, ast, an) < 0
    ret 3
  end
  let emitted i32 = emit_c(source, tokens, ast, an, out, 262144)
  if emitted < 0
    ret 4
  end
  let path i8[64] = "/tmp/etl_c1_source_to_c.c"
  if etl_write_file1024(path, out, emitted) < 0
    ret 5
  end
  ret 0
end
