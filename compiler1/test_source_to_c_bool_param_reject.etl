fn main() i32
  let source i8[256] = "fn truth(x bool) i32 if x ret 1 end ret 0 end fn main() i32 ret truth(true) end"
  let tokens Token[128]
  let ast AstNode[512]
  let n i32 = lex(source, 79, tokens, 128)
  if n < 0
    ret 1
  end
  let an i32 = parse(tokens, n, ast, 512)
  if an < 0
    ret 2
  end
  if sema(source, tokens, ast, an) < 0
    ret 0
  end
  ret 3
end
