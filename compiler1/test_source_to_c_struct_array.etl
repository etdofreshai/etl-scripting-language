extern fn etl_write_file1024(path i8[64], buf i8[1024], len i32) i32

fn main() i32
  let source i8[256] = "type Item structure value integer end fn main() integer let items Item[2] items[0].value = 19 items[1].value = 20 let i integer = 1 items[i].value = items[i].value + 3 return items[0].value + items[i].value end"
  let tokens Token[128]
  let ast AstNode[512]
  let out i8[1024]
  let n i32 = lex(source, 210, tokens, 128)
  if n < 0
    ret 1
  end
  let an i32 = parse(tokens, n, ast, 512)
  if an < 0
    ret 2
  end
  if sema(source, tokens, ast, an) < 0
    ret 3
  end
  let emitted i32 = emit_c(source, tokens, ast, an, out, 1024)
  if emitted < 0
    ret 4
  end
  let path i8[64] = "/tmp/etl_c1_source_to_c_struct_array.c"
  if etl_write_file1024(path, out, emitted) < 0
    ret 5
  end
  ret 0
end
