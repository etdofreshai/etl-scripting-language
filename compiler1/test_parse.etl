fn main() i32
  let source i8[256] = "fn main() i32 ret 42 end"
  let tokens Token[128]
  let ast AstNode[512]
  let n i32 = lex(source, 24, tokens, 128)
  if n != 9
    ret 1
  end
  let an i32 = parse(tokens, n, ast, 512)
  if an < 0
    ret 2
  end
  if ast[0].kind != AN_BLOCK()
    ret 3
  end
  if ast[1].kind != AN_TYPE()
    ret 4
  end
  if ast[2].kind != AN_INT()
    ret 5
  end
  if ast[3].kind != AN_RET()
    ret 6
  end
  if ast[4].kind != AN_LIST()
    ret 7
  end
  if ast[5].kind != AN_BLOCK()
    ret 8
  end
  if ast[6].kind != AN_FN()
    ret 9
  end
  ret 7
end
