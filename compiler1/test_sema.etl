fn test_source_local_chain() i32
  let source i8[256] = "fn main() i32 let x i32 = 10 let y i32 = x ret y end"
  let tokens Token[128]
  let ast AstNode[512]
  let n i32 = lex(source, 52, tokens, 128)
  if n < 0
    ret 1
  end
  let an i32 = parse(tokens, n, ast, 512)
  if an < 0
    ret 1
  end
  if sema(source, tokens, ast, an) != SEMA_OK()
    ret 1
  end
  ret 0
end

