fn main() i32
  let source i8[256] = "fn main() i32 ret 42 end"
  let tokens Token[128]
  let ast AstNode[512]
  let n i32 = lex(source, 24, tokens, 128)
  if n != 9
    ret 1
  end
  let an i32 = parse(tokens, n, ast, 512)
  if an < 0
    ret 2
  end
  if sema(source, tokens, ast, an) != SEMA_OK()
    ret 3
  end
  if test_duplicate_fn_ast() != 0
    ret 4
  end
  if test_duplicate_param_ast() != 0
    ret 5
  end
  if test_expr_stmt_not_call_ast() != 0
    ret 6
  end
  if test_return_outside_fn_ast() != 0
    ret 7
  end
  if test_valid_if() != 0
    ret 8
  end
  if test_invalid_if_condition() != 0
    ret 10
  end
  if test_valid_while() != 0
    ret 11
  end
  if test_invalid_while_condition() != 0
    ret 12
  end
  if test_assign_undeclared() != 0
    ret 13
  end
  if test_assign_declared() != 0
    ret 14
  end
  if test_use_undeclared_name() != 0
    ret 15
  end
  if test_let_then_use() != 0
    ret 16
  end
  if test_comparison_valid() != 0
    ret 17
  end
  if test_comparison_incompat() != 0
    ret 18
  end
  if test_bool_op_string() != 0
    ret 19
  end
  if test_bool_op_valid() != 0
    ret 20
  end
  if test_source_local_chain() != 0
    ret 21
  end
  if test_source_assign_declared() != 0
    ret 22
  end
  if test_source_undeclared_rejected() != 0
    ret 23
  end
  if test_source_extern_void_call_stmt() != 0
    ret 24
  end
  if test_source_extern_i32_call_expr() != 0
    ret 25
  end
  if test_source_extern_wrong_arg_count() != 0
    ret 26
  end
  if test_source_extern_void_call_return_rejected() != 0
    ret 27
  end
  if test_source_extern_void_call_let_rejected() != 0
    ret 28
  end
  ret 9
end
