fn set_ast(ast AstNode[512], idx i32, kind i32, a i32, b i32, c i32, token i32) i32
  ast[idx].kind = kind
  ast[idx].a = a
  ast[idx].b = b
  ast[idx].c = c
  ast[idx].token = token
  ret 0
end

fn test_duplicate_fn_ast() i32
  let source i8[256]
  let tokens Token[128]
  let ast AstNode[512]
  let same_name_token i32 = 10
  let unused_type i32 = -1

  let ok i32 = set_ast(ast, 0, AN_BLOCK(), -1, 0, 0, 0)
  ok = set_ast(ast, 1, AN_BLOCK(), -1, 0, unused_type, 0)
  ok = set_ast(ast, 2, AN_FN(), same_name_token, 0, 1, same_name_token)
  ok = set_ast(ast, 3, AN_BLOCK(), -1, 0, 0, 0)
  ok = set_ast(ast, 4, AN_BLOCK(), -1, 0, unused_type, 0)
  ok = set_ast(ast, 5, AN_FN(), same_name_token, 3, 4, same_name_token)
  ok = set_ast(ast, 6, AN_LIST(), 2, -1, 0, same_name_token)
  ok = set_ast(ast, 7, AN_LIST(), 5, 6, 0, same_name_token)
  ok = set_ast(ast, 8, AN_PROGRAM(), 7, 2, 0, 0)

  if ok != 0
    ret 1
  end
  if sema(source, tokens, ast, 9) != SEMA_ERROR()
    ret 1
  end
  ret 0
end

fn test_duplicate_param_ast() i32
  let source i8[256]
  let tokens Token[128]
  let ast AstNode[512]
  let fn_token i32 = 20
  let param_token i32 = 21
  let unused_type i32 = -1

  let ok i32 = set_ast(ast, 0, AN_PARAM(), param_token, unused_type, 0, param_token)
  ok = set_ast(ast, 1, AN_PARAM(), param_token, unused_type, 0, param_token)
  ok = set_ast(ast, 2, AN_LIST(), 0, -1, 0, param_token)
  ok = set_ast(ast, 3, AN_LIST(), 1, 2, 0, param_token)
  ok = set_ast(ast, 4, AN_BLOCK(), 3, 2, 0, param_token)
  ok = set_ast(ast, 5, AN_BLOCK(), -1, 0, unused_type, fn_token)
  ok = set_ast(ast, 6, AN_FN(), fn_token, 4, 5, fn_token)
  ok = set_ast(ast, 7, AN_LIST(), 6, -1, 0, fn_token)
  ok = set_ast(ast, 8, AN_PROGRAM(), 7, 1, 0, 0)

  if ok != 0
    ret 1
  end
  if sema(source, tokens, ast, 9) != SEMA_ERROR()
    ret 1
  end
  ret 0
end

fn test_expr_stmt_not_call_ast() i32
  let source i8[256]
  let tokens Token[128]
  let ast AstNode[512]
  let fn_token i32 = 30
  let expr_token i32 = 31
  let unused_type i32 = -1

  let ok i32 = set_ast(ast, 0, AN_BLOCK(), -1, 0, 0, fn_token)
  ok = set_ast(ast, 1, AN_NAME(), expr_token, 0, 0, expr_token)
  ok = set_ast(ast, 2, AN_EXPR_STMT(), 1, 0, 0, expr_token)
  ok = set_ast(ast, 3, AN_LIST(), 2, -1, 0, expr_token)
  ok = set_ast(ast, 4, AN_BLOCK(), 3, 1, unused_type, fn_token)
  ok = set_ast(ast, 5, AN_FN(), fn_token, 0, 4, fn_token)
  ok = set_ast(ast, 6, AN_LIST(), 5, -1, 0, fn_token)
  ok = set_ast(ast, 7, AN_PROGRAM(), 6, 1, 0, 0)

  if ok != 0
    ret 1
  end
  if sema(source, tokens, ast, 8) != SEMA_ERROR()
    ret 1
  end
  ret 0
end

fn test_return_outside_fn_ast() i32
  let source i8[256]
  let tokens Token[128]
  let ast AstNode[512]
  let ret_token i32 = 40
  let scope i32[64]
  scope[0] = 0

  let ok i32 = set_ast(ast, 0, AN_INT(), 1, 0, 0, ret_token)
  ok = set_ast(ast, 1, AN_RET(), 0, 0, 0, ret_token)
  ok = set_ast(ast, 2, AN_LIST(), 1, -1, 0, ret_token)
  ok = set_ast(ast, 3, AN_BLOCK(), 2, 1, 0, ret_token)

  if ok != 0
    ret 1
  end
  if sema_validate_block(source, tokens, ast, 3, 0, scope, 1) != SEMA_ERROR()
    ret 1
  end
  ret 0
end

