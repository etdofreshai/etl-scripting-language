  let ok i32 = set_ast(ast, 0, AN_NAME(), var_token, 0, 0, var_token)
  ok = set_ast(ast, 1, AN_INT(), 42, 0, 0, 2)
  ok = set_ast(ast, 2, AN_ASSIGN(), 0, 1, 0, 3)

  if ok != 0
    ret 1
  end
  if sema_validate_stmt(source, tokens, ast, 2, 1, scope, 1) != SEMA_OK()
    ret 1
  end
  ret 0
end

