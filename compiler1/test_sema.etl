fn test_let_then_use() i32
  let source i8[256]
  let tokens Token[128]
  let ast AstNode[512]
  let scope i32[64]
  scope[0] = 0

  let x_name_tok i32 = 80

  let ok i32 = set_ast(ast, 0, AN_INT(), 1, 0, 0, 1)
  ok = set_ast(ast, 1, AN_TYPE(), 0, 0, 0, 2)
  ok = set_ast(ast, 2, AN_LET(), x_name_tok, 1, 0, 3)
  ok = set_ast(ast, 3, AN_NAME(), x_name_tok, 0, 0, x_name_tok)
  ok = set_ast(ast, 4, AN_INT(), 2, 0, 0, 5)
  ok = set_ast(ast, 5, AN_BINARY(), TK_PLUS(), 3, 4, 6)
  ok = set_ast(ast, 6, AN_RET(), 5, 0, 0, 7)
  ok = set_ast(ast, 7, AN_LIST(), 6, 8, 0, 9)
  ok = set_ast(ast, 8, AN_LIST(), 2, -1, 0, 10)
  ok = set_ast(ast, 9, AN_BLOCK(), 7, 2, 0, 11)

  if ok != 0
    ret 1
  end
  if sema_validate_block(source, tokens, ast, 9, 1, scope, 1) != SEMA_OK()
    ret 1
  end
  ret 0
end

