fn TK_RPAREN() i32 ret 21 end
fn TK_COMMA() i32 ret 22 end
fn TK_LBRACKET() i32 ret 23 end
fn TK_RBRACKET() i32 ret 24 end
fn TK_DOT() i32 ret 25 end
fn TK_EQUAL() i32 ret 26 end
fn TK_PLUS() i32 ret 27 end
fn TK_MINUS() i32 ret 28 end
fn TK_STAR() i32 ret 29 end
fn TK_SLASH() i32 ret 30 end
fn TK_PERCENT() i32 ret 31 end
