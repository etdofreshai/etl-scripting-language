fn AN_PROGRAM() i32 ret 1 end
fn AN_LIST() i32 ret 2 end
fn AN_FN() i32 ret 3 end
fn AN_EXTERN_FN() i32 ret 4 end
fn AN_STRUCT() i32 ret 5 end
fn AN_FIELD() i32 ret 6 end
fn AN_PARAM() i32 ret 7 end
fn AN_TYPE() i32 ret 8 end
fn AN_BLOCK() i32 ret 9 end
fn AN_LET() i32 ret 10 end
fn AN_ASSIGN() i32 ret 11 end
fn AN_IF() i32 ret 12 end
fn AN_ELIF() i32 ret 13 end
fn AN_WHILE() i32 ret 14 end
fn AN_RET() i32 ret 15 end
fn AN_EXPR_STMT() i32 ret 16 end
fn AN_INT() i32 ret 17 end
fn AN_STRING() i32 ret 18 end
fn AN_BOOL() i32 ret 19 end
fn AN_NAME() i32 ret 20 end
fn AN_CALL() i32 ret 21 end
fn AN_INDEX() i32 ret 22 end
fn AN_FIELD_ACCESS() i32 ret 23 end
fn AN_BINARY() i32 ret 24 end
fn AN_UNARY() i32 ret 25 end
