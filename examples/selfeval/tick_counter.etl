external function etl_print_i32(value integer)

function main() integer
  let pos integer = 0
  let vel integer = 1
  let tick integer = 0
  while tick < 5
    etl_print_i32(tick)
    etl_print_i32(pos)
    pos = pos + vel
    vel = vel + 1
    tick = tick + 1
  end
  etl_print_i32(tick)
  etl_print_i32(pos)
  return pos
end
