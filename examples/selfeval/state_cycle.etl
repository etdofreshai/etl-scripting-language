external function etl_print_i32(value integer)

function next_state(s integer) integer
  if s == 0
    return 1
  elif s == 1
    return 2
  else
    return 0
  end
end

function main() integer
  let state integer = 0
  let tick integer = 0
  while tick < 6
    etl_print_i32(tick)
    etl_print_i32(state)
    state = next_state(state)
    tick = tick + 1
  end
  etl_print_i32(tick)
  etl_print_i32(state)
  return state
end
