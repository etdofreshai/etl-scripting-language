extern fn etl_print_i32(value i32)

fn next_state(s i32) i32
  if s == 0
    ret 1
  elif s == 1
    ret 2
  else
    ret 0
  end
end

fn main() i32
  let state i32 = 0
  let tick i32 = 0
  while tick < 6
    etl_print_i32(tick)
    etl_print_i32(state)
    state = next_state(state)
    tick = tick + 1
  end
  etl_print_i32(tick)
  etl_print_i32(state)
  ret state
end
